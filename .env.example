MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/leadscraper
PORT=5000
NODE_ENV=development

# Google Places API (required for fetching leads). Create key in Google Cloud, enable "Places API".
GOOGLE_PLACES_API_KEY=your_google_places_api_key
# Set to true to allow API calls; when false, fetch will throw (free-tier safety).
GOOGLE_PLACES_API_ENABLED=false
# Monthly request limit for free tier (default 5000). Each Text Search + each Place Details = 1 request.
FREE_TIER_MONTHLY_LIMIT=5000
